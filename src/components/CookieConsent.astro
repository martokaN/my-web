---

---

<style is:global>
	@import "vanilla-cookieconsent/dist/cookieconsent.css";

	:root {
		/* Background and text */
		--cc-bg: var(--bg-surface);
		--cc-primary-color: var(--clr-brand);
		--cc-secondary-color: var(--txt-muted);

		/* Primary button */
		--cc-btn-primary-bg: var(--clr-accent);
		--cc-btn-primary-color: var(--clr-brand);
		--cc-btn-primary-border-color: var(--clr-accent);
		--cc-btn-primary-hover-bg: var(--clr-accent);
		--cc-btn-primary-hover-color: var(--clr-brand);
		--cc-btn-primary-hover-border-color: var(--clr-accent);

		/* Secondary button */
		--cc-btn-secondary-bg: transparent;
		--cc-btn-secondary-color: var(--clr-accent);
		--cc-btn-secondary-border-color: var(--clr-accent);
		--cc-btn-secondary-hover-bg: var(--clr-accent);
		--cc-btn-secondary-hover-color: var(--clr-brand);
		--cc-btn-secondary-hover-border-color: var(--clr-accent);

		/* Divider and border radius */
		--cc-separator-border-color: var(--clr-border);
		--cc-modal-border-radius: var(--border-radius);
		--cc-btn-border-radius: var(--border-radius);
		--cc-overlay-bg: rgba(0, 0, 0, 0.6);

		/* Toggle */
		--cc-toggle-on-bg: var(--clr-accent);
		--cc-toggle-off-bg: var(--txt-muted);
		--cc-toggle-on-knob-bg: var(--clr-brand);
		--cc-toggle-off-knob-bg: var(--clr-brand);
		--cc-toggle-readonly-bg: var(--clr-border);
		--cc-toggle-readonly-knob-bg: var(--txt-muted);
		--cc-toggle-readonly-knob-icon-color: var(--clr-border);

		/* Category cookies */
		--cc-cookie-category-block-bg: var(--bg-surface-hover);
		--cc-cookie-category-block-border: var(--clr-border);
		--cc-cookie-category-block-hover-bg: var(--bg-surface-hover);
		--cc-cookie-category-block-hover-border: var(--clr-accent);
		--cc-cookie-category-expanded-block-bg: var(--bg-surface-hover);
		--cc-cookie-category-expanded-block-hover-bg: var(--clr-border);

		/* Footer */
		--cc-footer-bg: var(--bg-main);
		--cc-footer-color: var(--txt-muted);
		--cc-footer-border-color: var(--clr-border);
	}

	/* Buttons - animation */
	#cc-main .cm__btn,
	#cc-main .pm__btn {
		transition:
			transform var(--transition-fast),
			filter var(--transition-fast) !important;
		will-change: transform;
		backface-visibility: hidden;
	}

	#cc-main .cm__btn:hover,
	#cc-main .pm__btn:hover {
		transform: scale(1.03);
	}

	#cc-main .cm__btn:active,
	#cc-main .pm__btn:active {
		transform: scale(0.97);
		filter: brightness(0.9);
	}

	/* Opened category */
	#cc-main .pm__section--toggle .pm__section-desc-wrapper {
		border-color: var(--clr-border);
		background: var(--bg-surface-hover);
	}

	/* Text */
	#cc-main .cm__title,
	#cc-main .pm__title {
		color: var(--clr-brand);
	}

	#cc-main .cm__desc,
	#cc-main .pm__section-desc,
	#cc-main .pm__section-title {
		color: var(--txt-main);
	}

	/* Link */
	#cc-main a:hover {
		background-size: 0 !important;
	}
</style>

<script>
	import * as CookieConsent from "vanilla-cookieconsent";
	import { config } from "../lib/cookieconsent";

	CookieConsent.run(config);
</script>
