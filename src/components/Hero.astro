---
import { Image } from "astro:assets";
import heroImg from "../assets/hero.png";
---

<section class="hero">
  <div class="container">
    <Image
      src={heroImg}
      alt="Hero image"
      layout="full-width"
      sizes="(min-width: 48em) 1000px, 100vw"
      priority
    />

    <div class="img-overlay"></div>

    <div class="hero-content | flow text-center" style="--flow-space: 1rem">
      <h1 class="fs-hero">
        <span class="text-accent">Čistý kód.</span>
        <br /> Čisté řešení.
      </h1>
      <p class="text-muted">
        Stavím moderní weby na míru. Hlavní je rychlost, čistý design a
        dlouhodobá udržitelnost.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: calc(100vh - var(--nav-height));
  }

  .hero img {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    top: 0;
    left: 0;
    z-index: -2;
  }

  .img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(22, 22, 26, 0.5) 0%,
      rgba(22, 22, 26, 0.6) 50%,
      rgba(25, 25, 31, 0.9) 100%
    );
    z-index: -1;
  }

  .hero p {
    max-width: 50ch;
    margin-inline: auto;
  }
</style>
